# Firebase Web-Config — Werte aus Firebase Console > Projekteinstellungen > Allgemein > Web-App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Namespace dieses Lernsets — alle Firestore-Pfade liegen unter abstimmungen/<UNIT_ID>/
NEXT_PUBLIC_UNIT_ID=ki26

# ── Server-only (Lehrer-Tier via Next.js Route Handlers + Firebase Admin SDK) ──
# Vollstaendiges Service-Account-JSON als String (roh ODER Base64-kodiert).
# Generieren: Firebase Console > Projekteinstellungen > Dienstkonten >
# "Neuen privaten Schluessel generieren". NIEMALS committen.
# In Vercel als Environment Variable hinterlegen (Production + Preview).
FIREBASE_SERVICE_ACCOUNT=
